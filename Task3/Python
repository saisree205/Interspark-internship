import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load Dataset
df = pd.read_csv('website_traffic.csv')

# Data Cleaning
df.drop_duplicates(inplace=True)
df.fillna(0, inplace=True)

# Total Users
print("Total Users:", df['User_ID'].nunique())

# Sessions
print("Total Sessions:", df['Session_ID'].nunique())

# Traffic Sources
traffic = df['Traffic_Source'].value_counts()

plt.figure(figsize=(8,5))
traffic.plot(kind='bar')
plt.title("Traffic Sources")
plt.show()

# Top Landing Pages
landing = df['Landing_Page'].value_counts().head(10)

plt.figure(figsize=(8,5))
landing.plot(kind='bar')
plt.title("Top Landing Pages")
plt.show()

# Bounce Rate
bounce_rate = (df['Bounce'].sum()/len(df))*100
print("Bounce Rate:", bounce_rate)

# Session Duration
plt.figure(figsize=(8,5))
sns.histplot(df['Session_Duration'])
plt.title("Session Duration")
plt.show()
